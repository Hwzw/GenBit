DATABASE_URL=postgresql+asyncpg://genbit:genbit@localhost:5432/genbit
REDIS_URL=redis://localhost:6379/0
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# --- Production / Railway ---
# DATABASE_URL: Railway's Postgres plugin injects postgresql://... — config.py
#   auto-normalizes it to postgresql+asyncpg:// and converts sslmode= to ssl=
# CORS_ORIGINS: set to your Railway/custom domain(s), comma-separated
#   e.g. https://genbit.example.com,https://genbit-production.up.railway.app
# SECRET_KEY: generate with
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# NCBI rate limiting
# NCBI_CONCURRENT_WITH_KEY=10
# NCBI_CONCURRENT_WITHOUT_KEY=3

# External API base URLs
# EPD_BASE_URL=https://epd.expasy.org/api
# ENSEMBL_BASE_URL=https://rest.ensembl.org
# UNIPROT_BASE_URL=https://rest.uniprot.org
# JASPAR_BASE_URL=https://jaspar.elixir.no/api/v1
# COCOPUTS_BASE_URL=https://dnahive.fda.gov/dna.cgi

# HTTP timeouts (seconds)
# HTTP_TIMEOUT=30.0
# COCOPUTS_TIMEOUT=60.0

# Cache TTLs (seconds)
# CACHE_TTL_GENE=86400
# CACHE_TTL_PROTEIN=86400
# CACHE_TTL_ORGANISM=604800
# CACHE_TTL_CODON_TABLE=604800

# Codon optimization
# GC_CONTENT_WINDOW=50
# REPEAT_AVOIDANCE_PATTERN=9x1mer
# FALLBACK_CODON_TABLE=e_coli_316407

# Scoring thresholds
# PROMOTER_STRONG_THRESHOLD=80
# PROMOTER_MODERATE_THRESHOLD=40
# TERMINATOR_HIGH_THRESHOLD=90
# TERMINATOR_MODERATE_THRESHOLD=80
